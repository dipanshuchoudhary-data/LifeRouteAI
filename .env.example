# LifeRoute AI - Environment Variables
# Copy this file to .env and fill in your values

# -- OpenRouter (LLM - Claude via OpenAI-compatible API) --
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Model slug on OpenRouter - see https://openrouter.ai/models
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# Optional - shown on OpenRouter dashboard for app attribution
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_NAME=LifeRoute AI

# -- Supabase (Database + pgvector) --
# Use PROJECT URL only - do NOT add /rest/v1/ (SDK adds it automatically)
# From dashboard: Settings -> API -> Project URL
SUPABASE_URL=https://projecturl.supabase.co
# Service role secret key (starts with eyJ...) - NOT the REST URL
SUPABASE_KEY=your-service-role-key-here

# -- App Config --
MOCK_MODE=false
# Set to true to skip all LLM/DB calls - uses pre-computed demo results

# -- URLs --
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000
COPILOT_CONNECTOR_URL=http://localhost:8000
